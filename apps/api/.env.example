# API Environment Variables
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://lifeflow:lifeflow@localhost:5432/lifeflow?schema=public"

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.lifeflow.app

# AI (optional — graceful fallback when absent)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Sentry crash reporting (optional — disabled when absent)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
